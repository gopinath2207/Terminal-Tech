# Server Environment Variables
# !! IMPORTANT: NEVER commit real values. Copy this file to .env and fill in your values !!

# ── Server ─────────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=production

# ── MongoDB Atlas ─────────────────────────────────────────────────────────────
MONGO_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/?appName=<AppName>
MONGO_DB_NAME=affiliateblog

# ── JWT ───────────────────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=REPLACE_WITH_64_BYTE_RANDOM_HEX
JWT_EXPIRES_IN=7d

# ── Cloudinary ────────────────────────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
CLOUDINARY_FOLDER=affiliateblog

# ── CORS ──────────────────────────────────────────────────────────────────────
# Your deployed frontend URL e.g. https://yourdomain.com
CLIENT_URL=https://yourdomain.com

# ── Admin Registration ────────────────────────────────────────────────────────
# A secret token required to create the first admin account (keep this private)
ADMIN_REGISTER_SECRET=REPLACE_WITH_A_STRONG_RANDOM_SECRET
