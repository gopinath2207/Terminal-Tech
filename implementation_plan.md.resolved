## MongoDB Schemas

### 1. User Model (`User.model.js`)
```js
const userSchema = new Schema({
  username: { type: String, required: true, unique: true, trim: true },
  email:    { type: String, required: true, unique: true, lowercase: true },
  password: { type: String, required: true },          // bcrypt hashed
  role:     { type: String, enum: ['admin'], default: 'admin' },
}, { timestamps: true });
// Index: email (unique auto-indexed)
```

### 2. Post Model (`Post.model.js`)
```js
const postSchema = new Schema({
  title:        { type: String, required: true, trim: true },
  slug:         { type: String, required: true, unique: true },  // ← INDEXED
  excerpt:      { type: String, required: true, maxlength: 300 },
  content:      { type: String, required: true },                 // HTML/Markdown
  category:     { type: String, required: true, index: true },    // ← INDEXED
  tags:         [String],
  coverImage:   {
    url:          String,           // Cloudinary URL (f_auto,q_auto)
    publicId:     String,           // for deletion
  },
  products:     [{ type: Schema.Types.ObjectId, ref: 'Product' }], // embedded comparison
  isTrending:   { type: Boolean, default: false },
  isTopPick:    { type: Boolean, default: false },
  views:        { type: Number, default: 0 },
  author:       { type: Schema.Types.ObjectId, ref: 'User' },
  metaTitle:    String,
  metaDesc:     String,
  published:    { type: Boolean, default: false },
}, { timestamps: true });

postSchema.index({ slug: 1 });
postSchema.index({ category: 1 });
postSchema.index({ isTrending: 1, createdAt: -1 });
```

### 3. Product Model (`Product.model.js`)
```js
const productSchema = new Schema({
  name:           { type: String, required: true },
  slug:           { type: String, required: true, unique: true }, // ← INDEXED
  description:    { type: String },
  image:          {
    url:          String,       // Cloudinary URL
    publicId:     String,
  },
  affiliateUrl:   { type: String, required: true },  // original long URL
  shortCode:      { type: String, required: true, unique: true }, // redirect key
  price:          String,
  rating:         { type: Number, min: 0, max: 5 },
  isBestValue:    { type: Boolean, default: false },
  specs:          [{ key: String, value: String }],  // for comparison table
  category:       { type: String, index: true },     // ← INDEXED
  clicks:         { type: Number, default: 0 },
}, { timestamps: true });

productSchema.index({ slug: 1 });
productSchema.index({ category: 1 });
productSchema.index({ shortCode: 1 });
```

### 4. Click Model (`Click.model.js`) — Analytics
```js
const clickSchema = new Schema({
  product:    { type: Schema.Types.ObjectId, ref: 'Product', required: true },
  ip:         String,
  userAgent:  String,
  referer:    String,
}, { timestamps: true });

clickSchema.index({ product: 1, createdAt: -1 });
```

